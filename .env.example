# Copy to .env for local dev. NEVER commit the real .env (it is gitignored).
# In production these are set as host environment variables / secrets.

# Claude coach key (read ONLY from the environment; bare, no prefix).
# Without it the coach falls back to rule-based notes — the app still runs.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Only needed if the frontend is hosted on a DIFFERENT origin than the
# backend (separate-service deploy). For the default single-service deploy the
# frontend is same-origin, so CORS is not used and this can be left unset.
# Comma-separated list is allowed.
# FRONTEND_ORIGIN=https://your-frontend.example.com

# Optional overrides (pydantic-settings, CONFLUENCE_ prefix):
# CONFLUENCE_COACH_MODEL=claude-haiku-4-5
# CONFLUENCE_AUTO_RUN_SWEEP_ON_BOOT=true
